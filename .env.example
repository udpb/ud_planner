# UD-Ops Workspace — 개발 환경변수 예시
# 이 파일을 .env 로 복사 후 실제 값 채우기 (.env 는 .gitignore)
# 프로덕션 배포는 .env.production.example 참조

# ─────────────────────────────────────────
# [필수] 데이터베이스 (PostgreSQL)
# ─────────────────────────────────────────
# 로컬: docker-compose up postgres
# 형식: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ud_ops"

# ─────────────────────────────────────────
# [필수] AI — Phase L1 (2026-04-27) 이후
# 둘 중 최소 하나는 필수. 둘 다 있으면 Gemini Primary / Claude Fallback.
# ─────────────────────────────────────────
# Google Gemini 3.1 Pro Preview (Primary)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-pro-preview"

# Anthropic Claude Sonnet 4.6 (Fallback)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────
# [필수] NextAuth — 인증
# ─────────────────────────────────────────
# 32자 이상 랜덤. 생성: openssl rand -base64 32
AUTH_SECRET=""

# 로컬: http://localhost:3000  /  프로덕션: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────
# [선택] Google OAuth — 로그인 기능
# ─────────────────────────────────────────
# 미설정 시 개발 모드에서 Credentials 로그인만 사용 가능
# 발급: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─────────────────────────────────────────
# [선택] 앱 URL — 외부 링크/이메일 등에 사용
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────
# [선택] GitHub — 코치 DB 동기화
# ─────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_COACHES_REPO="underdogs-org/coaches-db"
GITHUB_COACHES_BRANCH="main"
GITHUB_COACHES_FILE="coaches_db.json"

# 2026-05-03: Google Sheets 연동 폐기 (코치 단가는 Coach 모델, 피드백 흐름 제거).

# ─────────────────────────────────────────
# [선택, 강력 권장] Supabase mirror — Phase Bridge 1 (2026-05-03)
# ─────────────────────────────────────────
# ud-ops Project 가 생성/수정될 때마다 coaching-log/coach-finder 가 사용하는
# Supabase business_plans 에 자동 mirror.
#
# 효과:
#   - PM 이 Project.status=IN_PROGRESS 또는 isBidWon=true 로 set 하면
#     Supabase 에 status='won' 으로 mirror → bp_on_won 트리거 발동 →
#     projects + project_members 자동 생성 → 코치들이 coaching-log 에서
#     프로젝트 즉시 확인 가능.
#
# 미설정 시 mirror 비활성 (Project 저장은 정상 작동, 단지 cross-app
# lifecycle 이 깨짐 — 코치들이 coaching-log 에서 빈 화면을 봄).
#
# 자세한 설계: ../underdogs-coaching-log/docs/INTEGRATED_ARCHITECTURE.md §4.1
# 구현: src/lib/supabase-sync.ts
SUPABASE_URL="https://zwvrtxxgctyyctirntzj.supabase.co"
# Supabase Dashboard → Project Settings → API → service_role → "Reveal" 후 복사.
# RLS 우회 슈퍼 키 — 절대 브라우저/git/메신저 노출 금지. 서버 전용.
SUPABASE_SERVICE_ROLE=""

# ─────────────────────────────────────────
# [선택] Sentry 모니터링 — Phase 4-coach-integration (2026-05-03)
# ─────────────────────────────────────────
# DSN 있을 때만 활성. logger.error / logger.warn 가 자동 수집.
# 가입: https://sentry.io → 새 Next.js 프로젝트 생성 → DSN 복사
# SENTRY_DSN=""

# ─────────────────────────────────────────
# [선택] Playwright E2E 시나리오 활성
# ─────────────────────────────────────────
# 본 변수가 설정돼 있어야 authenticated project (DB seed + storageState) 실행됨.
# 미설정 시: smoke + auth-flow 만 실행, authenticated 13건은 skip.
#
# 형식: 32자 이상 랜덤 (예: openssl rand -hex 24)
# E2E_SECRET=""
#
# AI mock 활성 — 실제 Gemini/Claude 호출 없이 fixture JSON 반환.
# E2E 비용 절약 + 결정적 결과. true 권장.
# PLAYWRIGHT_MOCK_AI="true"

# ─────────────────────────────────────────
# [선택, dev 권장] Wave V — Express+Deep 통합 패러다임 (ADR-015, F0)
# ─────────────────────────────────────────
# true 면 /projects/[id] 가 5 Stage 단일 화면 (Progressive Disclosure) 으로 렌더,
# /projects/[id]/express 는 /projects/[id] 로 redirect.
#
# false (또는 미설정) 면 기존 Express/Deep 두 화면 분리 동작 — 회귀 0.
# 운영 기본 OFF. dev/내부 테스트만 ON 권장.
#
# 자세한 설계: docs/decisions/015-wave-v-full-integration-ai-auto-build.md
# 단일 helper: src/lib/feature-flags.ts
# EXPRESS_PARADIGM_V3="false"

# ─────────────────────────────────────────
# [필수, 운영] Brain — Phase B·C·D·E (2026-05-26) ⭐
# ─────────────────────────────────────────
# Vercel Cron 인증 — 매주/매일 자동 실행되는 brain cron 보호.
# 미설정 시 dev 편의상 cron API 인증 우회 (운영은 반드시 설정).
# 생성: openssl rand -base64 32
CRON_SECRET=""

# Public Brain API token — /api/v1/brain/* 외부 시스템 연동.
# 미설정 시 public API 비활성 (503 응답).
# Bearer 인증: Authorization: Bearer <BRAIN_PUBLIC_API_TOKEN>
# 발급: openssl rand -hex 32
BRAIN_PUBLIC_API_TOKEN=""

# Drive watch — W30 cron 이 polling 으로 감시할 폴더 ID 목록 (comma-separated).
# 예: 1D_njCi1iOVMh4rHFcWxLErm-TPRTweqU,1LmzpJMIdH-ZdjGipsAJ0nopnwElKIFBN
# 미설정 시 W30 cron 은 no-op (Drive watch 비활성).
DRIVE_WATCH_FOLDERS=""

# Slack webhook — Brain 알림 통보 (freshness alert · 신규 도메인 감지).
# 미설정 시 알림 skip (DB 결과만 반환).
# 발급: Slack → Apps → Incoming Webhooks
# SLACK_FRESHNESS_WEBHOOK=""

# Render worker — DECK-3b (ADR-025). 별도 렌더 워커(render-worker/server.mjs · Cloud Run/컨테이너)
# 가 자체완결 HTML 을 받아 chromium 으로 PDF 를 반환한다. Next 앱(/api/projects/[id]/deck/pdf)이
# 이 URL 로 HTTP 호출. 미설정 시 기본값 http://localhost:8080 (로컬 워커).
# RENDER_WORKER_URL="http://localhost:8080"
# 워커 인증 토큰 — 워커에 RENDER_WORKER_TOKEN 이 설정돼 있으면 동일 값을 X-Render-Token 으로 보냄.
# 로컬 dev(토큰 미설정)면 빈 값이어도 통과.
# RENDER_WORKER_TOKEN=""
