// UD-Ops Workspace — Prisma Schema v1.0
// 언더독스 교육 기획 자동화 웹앱

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// [AUTH] 사용자 및 역할
// ─────────────────────────────────────────

enum UserRole {
  PM
  DIRECTOR
  CM
  FM
  COACH
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      UserRole @default(PM)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  agentSessions AgentSession[]
  // 2026-05-03 ADR-012: taskAssignees TaskAssignee[] 제거 (Task 모델 함께 제거)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// [B] 코치 데이터
// ─────────────────────────────────────────

enum CoachTier {
  TIER1
  TIER2
  TIER3
}

enum CoachCategory {
  PARTNER_COACH
  COACH
  GLOBAL_COACH
  CONSULTANT
  INVESTOR
}

enum TaxType {
  BUSINESS
  OTHER
}

model Coach {
  id               String        @id @default(cuid())
  githubId         Int?          @unique
  name             String
  email            String?
  phone            String?
  gender           String?
  location         String?
  regions          String[]
  organization     String?
  position         String?
  industries       String[]
  expertise        String[]
  roles            String[]
  overseas         Boolean       @default(false)
  overseasDetail   String?
  toolsSkills      String?       @db.Text
  intro            String?       @db.Text
  careerHistory    String?       @db.Text
  education        String?
  underdogsHistory String?       @db.Text
  currentWork      String?       @db.Text
  careerYears      Int?
  careerYearsRaw   String?
  photoUrl         String?
  businessType     String?
  country          String        @default("한국")
  language         String[]      @default(["한국어"])
  hasStartup       Boolean       @default(false)
  isActive         Boolean       @default(true)
  mainField        String?
  category         CoachCategory @default(COACH)
  tier             CoachTier     @default(TIER2)

  // 단가
  lectureRateMain    Int?
  lectureRateSub     Int?
  coachRateMain      Int?
  coachRateSub       Int?
  specialLectureRate Int?
  dailyRateCoach     Int?
  dailyRateLecture   Int?
  taxType            TaxType @default(BUSINESS)
  needTransport      Boolean @default(false)
  transportEstimate  Int?
  needAccomm         Boolean @default(false)
  accommEstimate     Int?

  // 역량
  satisfactionAvg    Float?
  collaborationCount Int     @default(0)
  impactMethodLevel  String?
  lectureStyle       String?
  hasInvestExp       Boolean @default(false)

  // 가용성
  availableDays   String[]
  blockedPeriods  Json?
  onlineAvailable Boolean  @default(true)
  minLeadTimeDays Int      @default(7)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coachAssignments CoachAssignment[]
  satisfactionLogs SatisfactionLog[]
}

// ─────────────────────────────────────────
// [C] 교육 모듈
// ─────────────────────────────────────────

enum ModuleCategory {
  TECH_EDU
  STARTUP_EDU
  CAPSTONE
  MENTORING
  NETWORKING
  EVENT
  ACTION_WEEK
  SPECIAL_LECTURE
}

enum DeliveryMethod {
  LECTURE
  WORKSHOP
  PRACTICE
  MENTORING
  MIXED
  ACTION_WEEK
  ONLINE
}

enum Difficulty {
  INTRO
  MID
  ADVANCED
}

model Module {
  id              String         @id @default(cuid())
  moduleCode      String         @unique
  name            String
  category        ModuleCategory
  keywordTags     String[]
  method          DeliveryMethod
  durationHours   Float
  minParticipants Int            @default(5)
  maxParticipants Int            @default(50)
  difficulty      Difficulty     @default(INTRO)

  objectives String[]
  contents   String[]
  practices  String[]
  equipment  String[]
  outputs    String[]

  targetStages  String[]
  targetPresets String[]

  impactQ54Mapping String[]
  skills5D         String[]
  acttTargets      String[]
  aiRatio          Int      @default(0)
  expertRatio      Int      @default(100)

  prerequisites   String[]
  outcomeTypes    String[]
  conversionRates Json?
  conversionBasis String?

  isTheory  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculumItems CurriculumItem[]
}

// ─────────────────────────────────────────
// [A] 프로젝트 (RFP 기반)
// ─────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  PROPOSAL
  SUBMITTED
  IN_PROGRESS
  COMPLETED
  LOST
}

enum ProjectType {
  B2G
  B2B
}

model Project {
  id          String        @id @default(cuid())
  name        String
  client      String
  projectType ProjectType   @default(B2G)
  status      ProjectStatus @default(DRAFT)

  totalBudgetVat Int?
  supplyPrice    Int?

  projectStartDate DateTime?
  projectEndDate   DateTime?
  eduStartDate     DateTime?
  eduEndDate       DateTime?

  rfpRaw           String? @db.Text
  rfpParsed        Json?
  impactGoal       String? @db.Text
  logicModel       Json?
  externalResearch Json? // PM이 외부 LLM에서 수집한 리서치 (ExternalResearch[])
  strategicNotes   Json? // 전략 맥락 (StrategicNotes: clientHiddenWants, mustNotFail, etc.)
  // Phase G (ADR-009): 이 프로젝트에 투입할 UD 자산 ID 목록 (matchAssetsToRfp 결과 중 PM 승인)
  acceptedAssetIds Json? // string[] — UdAsset.id (src/lib/asset-registry.ts)
  evalCriteria     Json?
  constraints      Json?
  kpiTargets       Json?
  kpiActuals       Json?
  sroiCountry      String  @default("한국")
  sroiForecast     Json?
  sroiActual       Json?

  // Phase B: Step 1 기획 방향 산출물 (data-contract.md §1.2 RfpSlice)
  proposalBackground String? @db.Text
  proposalConcept    String? @db.Text
  keyPlanningPoints  Json? // string[]
  evalStrategy       Json? // EvalStrategy 객체 (eval-strategy.ts 참조)

  // Phase D: 예상 점수 (Phase D4 에서 본격 활용, B0 에서 필드만 준비)
  predictedScore Float?

  // Phase E (ADR-006): ProgramProfile v1.0 — 11축 사업 프로파일
  // 스키마: src/lib/program-profile.ts ProgramProfile 타입 참조
  programProfile Json?

  // Phase E (ADR-006): 연속사업 컨텍스트
  // programProfile.channel.isRenewal=true 일 때 **필수** — Gate 3 블로킹
  // 스키마: src/lib/program-profile.ts RenewalContext 타입 참조
  renewalContext Json?

  // Phase L (ADR-011): Express Track 1차본
  // 스키마: src/lib/express/schema.ts ExpressDraftSchema (zod)
  // 단일 Json 필드로 시작 — 향후 정규화 필요시 별도 테이블 분리
  expressDraft      Json?
  // true 면 신규 프로젝트 진입 시 사이드바/페이지가 Express 화면으로 이동
  expressActive     Boolean @default(false)
  // 챗봇 마지막 N 턴 캐시 (이탈 후 재진입 회복용)
  expressTurnsCache Json?

  pmId String?
  pm   User?   @relation(fields: [pmId], references: [id])

  isBidWon        Boolean?
  techEvalScore   Float?
  bidNotes        String?  @db.Text
  feedbackApplied Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculum            CurriculumItem[]
  coachAssignments      CoachAssignment[]
  budget                Budget?
  participants          Participant[]
  proposalSections      ProposalSection[]
  applicants            Applicant[]
  satisfactionResponses SatisfactionResponse[]
  coachingJournals      CoachingJournal[]
  agentSessions         AgentSession[]
  assetUsages           AssetUsage[]
  impactForecast        ImpactForecast?
  // 2026-05-03 ADR-012: tasks Task[] / expenses Expense[] 제거 (해당 모델 함께 제거)
}

// ─────────────────────────────────────────
// [C] 커리큘럼 아이템
// ─────────────────────────────────────────

model CurriculumItem {
  id        String  @id @default(cuid())
  projectId String
  moduleId  String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module    Module? @relation(fields: [moduleId], references: [id])

  sessionNo     Int
  track         String?
  title         String
  date          DateTime?
  startTime     String?
  endTime       String?
  durationHours Float
  venue         String?
  isOnline      Boolean   @default(false)
  isTheory      Boolean   @default(false)
  isActionWeek  Boolean   @default(false)

  assignedCoachId String?
  coachRole       String?
  order           Int
  notes           String?

  // 세션 내 시간 구성 (분 단위, 기본: 강의 15분 + 실습 35분)
  lectureMinutes  Int     @default(15)
  practiceMinutes Int     @default(35)
  // 1:1 코칭 세션 여부 (Action Week 페어 세션)
  isCoaching1on1  Boolean @default(false)
  isLocked        Boolean @default(false)

  // IMPACT 18모듈 매핑 (예: "I-1", "M-2") — AI 생성 시 자동 매핑됨
  impactModuleCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, sessionNo])
}

// ─────────────────────────────────────────
// [B] 코치 배정
// ─────────────────────────────────────────

enum AssignmentRole {
  MAIN_COACH
  SUB_COACH
  LECTURER
  SUB_LECTURER
  SPECIAL_LECTURER
  JUDGE
  PM_OPS
}

model CoachAssignment {
  id        String  @id @default(cuid())
  projectId String
  coachId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coach     Coach   @relation(fields: [coachId], references: [id])

  role            AssignmentRole
  sessions        Int            @default(1)
  hoursPerSession Float          @default(5)
  totalHours      Float?
  agreedRate      Int?
  totalFee        Int?
  taxRate         Float?
  netFee          Int?
  confirmed       Boolean        @default(false)
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, coachId, role])
}

// ─────────────────────────────────────────
// [D] 예산
// ─────────────────────────────────────────

model Budget {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  pcTotal    Int   @default(0)
  acTotal    Int   @default(0)
  margin     Int   @default(0)
  marginRate Float @default(0)

  items     BudgetItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum BudgetItemType {
  PC
  AC
}

model BudgetItem {
  id       String @id @default(cuid())
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  wbsCode   String
  type      BudgetItemType
  category  String
  name      String
  unit      String?
  unitPrice Int
  quantity  Float
  amount    Int
  notes     String?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// [운영] 실지출 / 태스크 / 참여자
// ─────────────────────────────────────────

// 2026-05-03 ADR-012 — Expense / Task / TaskAssignee 모델 제거 (미구현, 호출자 0)
// Project.tasks / Project.expenses / User.taskAssignees back-ref 도 함께 제거됨.

model Participant {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  track          String?
  team           String?
  stage          String?
  attendances    Json?
  attendanceRate Float    @default(0)
  graduated      Boolean  @default(false)
  absenceCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dogsResults           DogsResult[]
  acttResults           ActtResult[]
  startupStatusRecords  StartupStatusRecord[]
  startupDiagnosis      StartupDiagnosis[]
  satisfactionResponses SatisfactionResponse[]
  coachingJournals      CoachingJournal[]
  alumniRecords         AlumniRecord[]
}

// ─────────────────────────────────────────
// [제안서] 섹션
// ─────────────────────────────────────────

model ProposalSection {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionNo  Int
  title      String
  content    String   @db.Text
  version    Int      @default(1)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, sectionNo, version])
}

// ─────────────────────────────────────────
// [마스터] 비용 기준 / SROI 프록시 / 대상자 프리셋
// ─────────────────────────────────────────

model CostStandard {
  id          String         @id @default(cuid())
  wbsCode     String         @unique
  type        BudgetItemType
  category    String
  name        String
  description String?
  unit        String
  unitPrice   Int
  notes       String?
  isActive    Boolean        @default(true)
  updatedAt   DateTime       @updatedAt
}

// ─────────────────────────────────────────
// [마스터] Content Hub — UD Asset Registry v2 (ADR-010)
// ─────────────────────────────────────────

model ContentAsset {
  id       String @id @default(cuid())
  name     String
  category String // AssetCategory 유니온 (methodology · content · product · human · data · framework)

  // 계층 — 상품 → 세션/주차/챕터 (1 단)
  parentId String?
  parent   ContentAsset?  @relation("ContentAssetHierarchy", fields: [parentId], references: [id])
  children ContentAsset[] @relation("ContentAssetHierarchy")

  // 3중 태그 (Phase G UdAsset 동일)
  applicableSections Json // ProposalSectionKey[]
  valueChainStage    String // ValueChainStage
  evidenceType       String // 'quantitative' | 'structural' | 'case' | 'methodology'

  // 매칭 보조
  keywords          Json? // string[]
  programProfileFit Json? // Partial<ProgramProfile>

  // Wave N4 (2026-05-15): 의미 매칭용 임베딩 벡터
  // - Gemini text-embedding-004 (768 dim) 권장. 다른 모델 쓰면 dim 일치만 유지.
  // - null = 아직 임베딩 생성 안 됨 (배치 스크립트 대상)
  // - embeddingModel 로 검증 가능 (다른 모델이면 재생성 필요)
  embedding      Float[]
  embeddingModel String? // 예: 'gemini-text-embedding-004'
  embeddedAt     DateTime?

  // 제안서 반영
  narrativeSnippet String @db.Text
  keyNumbers       Json? // string[]

  // 상태 + 버전
  status           String   @default("stable") // stable | developing | archived
  version          Int      @default(1)
  sourceReferences Json? // string[] — 외부 원본 URL
  lastReviewedAt   DateTime

  // 감사
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  usages AssetUsage[]

  @@index([category])
  @@index([valueChainStage])
  @@index([parentId])
  @@index([status])
}

/**
 * Wave N1 (2026-05-15) — 자산 사용 이력 + Win/Loss 라벨.
 * 목적:
 * - 자주 인용되어 수주된 자산 학습 → 매칭 가산점 (Wave N4 가중치 합산)
 * - 자산 freshness 보조 신호 (Wave N5)
 * - PM 별 / 채널별 자산 선호도 분석
 * 기록 시점:
 * - Express: 1차본 승인 시 differentiators.acceptedByPm=true 인 자산 일괄 기록
 * - Deep: ProposalSection 저장 시 narrativeSnippet 안에 박힌 자산 ID 자동 추적
 * wonProject:
 * - 처음 기록 시 null (수주 결과 미정)
 * - Project.isBidWon 갱신 시 cascade 로 채움 (서버 hook)
 */
model AssetUsage {
  id         String       @id @default(cuid())
  assetId    String
  asset      ContentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionKey String? // '1'..'7' (Express) | ProposalSectionKey (Deep)
  channel    String? // 'B2G' | 'B2B' | 'renewal'
  surface    String       @default("express") // 'express' | 'deep' | 'manual'
  wonProject Boolean? // Project.isBidWon 결과 cascade (null = 미정)
  techScore  Float? // Project.techEvalScore (있으면)
  notes      String?
  createdAt  DateTime     @default(now())

  @@index([assetId])
  @@index([projectId])
  @@index([wonProject])
  @@index([channel])
}

/**
 * Wave M2 (2026-05-15) — 사전 임팩트 forecast.
 * 1차본 승인 시 자동 생성. impact-measurement DB 의 계수 + 자체 엔진으로 계산.
 * impact-measurement 시스템과의 데이터 호환을 위해 같은 모양의 itemsJson / breakdownJson 보관.
 * 정책:
 * - projectId 당 1건 (덮어쓰기). 재계산 시 generatedAt 갱신.
 * - calibration: 'auto-conservative' (기본) / 'pm-adjusted' (PM이 보정함) / 'pm-locked'
 * - 사후실적은 별도 — 그건 impact-measurement 본진에서.
 */
model ImpactForecast {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /**
   * ISO-2: KR / JP / IN / ID
   */
  country String

  totalSocialValue Decimal
  beneficiaryCount Int

  /**
   * BreakdownEntry[] — { categoryId, value, combinedProxyValue, formulaVariables }
   * impact-measurement 의 breakdown 과 동일 모양.
   */
  breakdownJson Json

  /**
   * ForecastItemWithMeta[] — EducationItemInput + confidence + rationale.
   * AI 매핑 결과 (감사 가능 형태). PM 이 수정하면 같은 모양 유지.
   */
  itemsJson Json

  /**
   * 신뢰도 메타 — 'auto-conservative' | 'pm-adjusted' | 'pm-locked'
   */
  calibration     String  @default("auto-conservative")
  /**
   * AI 가 남긴 calibration 노트 (보수 추정 사유 등)
   */
  calibrationNote String? @db.Text

  /**
   * 1차본 시점 hash — draft 변경 후 재계산 필요 여부 판단용
   */
  basedOnDraftHash String?

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([country])
  @@index([generatedAt])
}

model SroiProxy {
  id               String   @id @default(cuid())
  country          String
  impactType       String
  subType          String
  formula          String
  proxyKrw         Int
  unit             String
  contributionRate Float?
  methodology      String?
  source           String?
  isRate           Boolean  @default(false)
  isActive         Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  @@unique([country, impactType, subType])
}

// 2026-05-03 ADR-012 (final): TargetPreset 제거 — ProgramProfile 11축 enum 으로 대체.
// 8건 시드 데이터는 PRD v5.1 잔재이며 ProgramProfile 의 targetSegment 로 흡수됨.

model SatisfactionLog {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id])
  projectName String
  role        String
  score       Float
  comment     String?
  loggedAt    DateTime @default(now())
}

// ─────────────────────────────────────────
// [PRD v5.0 신규] IMPACT 방법론, 어드민 설정 테이블
// ─────────────────────────────────────────

model ImpactModule {
  id              String   @id @default(cuid())
  stage           String
  stageOrder      Int
  moduleOrder     Int
  moduleCode      String   @unique
  moduleName      String
  coreQuestion    String
  workshopOutputs String[]
  durationMinutes Int      @default(50)
  sixRolesTarget  String[]
  isActive        Boolean  @default(true)

  contentMappings ContentMapping[]
}

model Content {
  id             String   @id @default(cuid())
  legacyCode     Int      @unique
  name           String
  format         String
  category       String
  targetAudience String[]
  businessField  String[]
  startupStage   String[]
  deliveryMethod String?
  sixRolesTarget String[]
  learningType   String?
  impactExpect   String?
  prerequisites  Int[]
  pptUrl         String?
  vodUrl         String?
  description    String?  @db.Text
  isActive       Boolean  @default(true)

  contentMappings ContentMapping[]
}

model ContentMapping {
  id             String       @id @default(cuid())
  impactModuleId String
  impactModule   ImpactModule @relation(fields: [impactModuleId], references: [id])
  contentId      String
  content        Content      @relation(fields: [contentId], references: [id])
  fitScore       Int          @default(3)
  notes          String?

  @@unique([impactModuleId, contentId])
}

// 2026-05-03 ADR-012 (final): 미구현 어드민 모델 + PRD v5.1 잔재 모델 모두 제거:
//   DesignRule (proposal-rules.ts 정적 룰로 대체)
//   AudienceProfile (ProgramProfile 로 통합)
//   WeightSuggestion (어드민 UI 0)
//   InternalLaborRate (CostStandard 가 단가 담당)
//   ServiceProduct (서비스 카탈로그 미구현)
//   TargetPreset (ProgramProfile 의 targetSegment 로 흡수)
// 모든 시드 데이터는 운영 결정으로 archive 됨.

// ─────────────────────────────────────────
// [v5.1 신규] 참여자 데이터 수집 (DOGS, ACTT, 창업현황, 만족도, 알럼나이)
// ─────────────────────────────────────────

// 참여자 지원서 (신청 정보)
model Applicant {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // ID 식별
  name     String
  teamName String?
  email    String
  phone    String?

  // 기본 정보
  gender      String?
  nationality String?   @default("대한민국")
  residence   String?
  birthDate   DateTime?
  affiliation String?
  jobMajor    String?
  education   String?

  // 창업 정보
  orgType          String? // 예비창업(개인)/예비창업(팀)/개인사업자/법인사업자
  companyName      String?
  industry         String? // 28개 산업분류 중 하나
  problemToSolve   String?  @db.Text
  itemIntro        String?  @db.Text
  businessLocation String?
  startupStage     String? // 아이디어/MVP/매출발생/투자유치완료 등
  teamSize         Int?
  teamMembers      String?
  certifications   String[]
  currentRevenue   Float?
  lastYearRevenue  Float?
  motivation       String?  @db.Text
  referralSource   String[]

  // 심사
  evaluationScores Json?
  selectionResult  String? // PENDING | PASSED | FAILED

  // 수료
  graduated     Boolean @default(false)
  participantId String? // 선발 후 Participant 레코드 연결

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// DOGS 성향 진단 결과
model DogsResult {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  projectId     String

  dogsType String? // D | O | G | S (최종 유형)
  answers  Json // {q1: 1~4, q2: 1~4, ..., q24: 1~4}
  scores   Json? // {D: 점수, O: 점수, G: 점수, S: 점수}

  createdAt DateTime @default(now())

  @@unique([participantId, projectId])
}

// ACTT 실행역량 진단 (사전/사후)
model ActtResult {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  projectId     String
  timing        String // PRE | POST

  answers      Json // {q1: 1~5, ..., q15: 1~5}
  domainScores Json? // {goalOrientation: avg, marketAwareness: avg, problemSolving: avg, experimentation: avg, persistence: avg}
  totalScore   Float?

  createdAt DateTime @default(now())

  @@unique([participantId, projectId, timing])
}

// 창업현황 (사전/사후)
model StartupStatusRecord {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  projectId     String
  timing        String // PRE | POST

  orgType           String?
  cumulativeRevenue Float?
  bepAchieved       Boolean?
  teamSize          Int?
  patents           String?
  investorName      String?
  investAmount      Float?
  govSupport        String?
  privateSupport    String?
  needs             String[]

  createdAt DateTime @default(now())

  @@unique([participantId, projectId, timing])
}

// 창업현황 진단 (사전, 루브릭 12항목)
model StartupDiagnosis {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  projectId     String

  scores           Json // {problemDefinition: 1~5, solutionDiff: 1~5, ..., irReadiness: 1~5}
  consultingNeeds  String[]
  biggestChallenge String?  @db.Text
  programGoal      String?  @db.Text
  coachRequest     String?  @db.Text

  createdAt DateTime @default(now())

  @@unique([participantId, projectId])
}

// 만족도 응답 (세션별 + 최종)
model SatisfactionResponse {
  id            String       @id @default(cuid())
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sessionId String? // CurriculumItem.id (회차별인 경우)
  timing    String // SESSION | FINAL
  section   String // overall | coaching | lecture | specialLecture | content | consulting | networking | popupEvent | demoDay | other

  responses Json // {q1: 5, q2: "텍스트", ...}
  coachName String? // 코칭 만족도 시 코치명

  createdAt DateTime @default(now())

  @@index([projectId, timing])
}

// 코칭일지
model CoachingJournal {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  coachName     String
  sessionDate   DateTime
  goals         String?      @db.Text
  activities    String?      @db.Text
  diagnosis     String?      @db.Text
  actionPlan    String?      @db.Text
  stage         String?
  photoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 알럼나이 추적
model AlumniRecord {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  surveyYear    Int

  activityStatus    String?
  startupIntent     String?
  dropoutReasons    String[]
  cumulativeRevenue Float?
  bepAchieved       Boolean?
  teamSize          Int?
  patents           String?
  investStatus      String?
  supportPrograms   String?
  alumniNeeds       String[]
  concerns          String[]
  phone             String?

  createdAt DateTime @default(now())

  @@unique([participantId, surveyYear])
}

// ─────────────────────────────────────────
// [Planning Agent] Phase 2 — 세션 영속화
// ─────────────────────────────────────────

enum AgentSessionStatus {
  IDLE
  PREPROCESSING
  INTERVIEWING
  SYNTHESIZING
  COMPLETED
  PAUSED
}

model AgentSession {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  pmId      String?
  pm        User?    @relation(fields: [pmId], references: [id], onDelete: SetNull)

  channel   String // bid | lead | renewal
  status    AgentSessionStatus @default(IDLE)
  stateJson Json // AgentState 전체 (history, intent, questions 등)

  turnsCompleted Int   @default(0)
  completeness   Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planningIntent PlanningIntentRecord?
  // 2026-05-03 ADR-012: pmFeedbacks PMFeedback[] 제거 (PMFeedback 모델 제거됨)

  @@index([projectId])
  @@index([pmId])
}

model PlanningIntentRecord {
  id        String       @id @default(cuid())
  sessionId String       @unique
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  projectId String?

  intentJson   Json // PlanningIntent 전체
  completeness Float  @default(0)
  confidence   String @default("low") // low | medium | high
  version      Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// 2026-05-03 ADR-012 — PMFeedback 모델 제거 (planning-agent 인터뷰 흐름 미사용,
// PlanningIntentRecord 만 활성)

// ─────────────────────────────────────────
// [Ingestion] 자료 업로드 → 자산 자동 고도화 (ADR-003)
// Phase A: 스키마 + 업로드 UI 뼈대 (실제 추출은 Phase D)
// ─────────────────────────────────────────

model IngestionJob {
  id          String    @id @default(cuid())
  kind        String // "proposal" | "curriculum" | "evaluator_question" | "strategy_interview"
  sourceFile  String? // blob 경로 또는 로컬 경로
  sourceUrl   String?
  metadata    Json // 사업명·발주처·수주여부·인터뷰 대상 등
  status      String    @default("queued") // "queued" | "processing" | "review" | "approved" | "rejected" | "failed"
  uploadedBy  String
  uploadedAt  DateTime  @default(now())
  processedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  error       String?

  extractedItems ExtractedItem[]

  @@index([kind, status])
  @@index([uploadedBy])
}

model ExtractedItem {
  id          String       @id @default(cuid())
  jobId       String
  job         IngestionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  targetAsset String // "winning_pattern" | "curriculum_archetype" | "evaluator_question" | "strategy_note"
  payload     Json // 자산 후보 필드
  confidence  Float        @default(0)
  status      String       @default("pending") // "pending" | "approved" | "rejected" | "edited"
  reviewNotes String?
  appliedAt   DateTime?
  appliedId   String? // 자산 테이블에 삽입된 레코드 ID

  // Phase D: 승인 후 생성된 자산 레코드 추적
  appliedWinningPatternId String? // 승인 후 생성된 WinningPattern.id
  appliedChannelPresetId  String? // ChannelPreset 업데이트 소스라면

  @@index([jobId])
  @@index([targetAsset, status])
}

// ─────────────────────────────────────────
// [Phase D] 수주 패턴 · 채널 프리셋 — 자산 축적 (ADR-003)
// ─────────────────────────────────────────

model WinningPattern {
  id              String  @id @default(cuid())
  // 출처
  sourceProject   String // 사업명 (예: "2025 종로구 서촌 로컬브랜드")
  sourceClient    String? // 발주처
  ingestionJobId  String? // 어느 IngestionJob 에서 왔는지
  extractedItemId String? // 어느 ExtractedItem 에서 승인되었는지

  // 분류
  sectionKey    String // ProposalSectionKey 값 (proposal-background/curriculum/...)
  channelType   String? // B2G | B2B | renewal
  outcome       String // "won" | "lost" | "pending" — 반면교사도 저장
  techEvalScore Float? // 기술평가 점수 (있으면)

  // 내용
  snippet    String   @db.Text // 섹션의 핵심 원문 스니펫
  whyItWorks String   @db.Text // 왜 먹혔는지 (추측+근거 명시)
  tags       String[] // ["청년창업", "정량KPI", ...]

  // Phase E (ADR-006): ProgramProfile snapshot — 유사도 매칭 입력
  // 스키마: src/lib/program-profile.ts ProgramProfile 타입 참조
  sourceProfile Json?

  // Phase E (ADR-006): 정규화 벡터 (향후 대량 매칭 최적화)
  profileVector Json?

  // 메타
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  approvedBy String? // userId
  embedding  Json? // pgvector 전환 전까지는 Json

  @@index([sectionKey, channelType, outcome])
  @@index([sourceProject])
}

// Phase E (ADR-006): 프로파일 태그 자동완성 + 재사용률 집계
// UI 에서 businessDomain · demographic · formats 등 free tag 를
// 이전에 쓴 값 기준으로 자동완성하기 위한 집계 테이블
// 2026-05-03 ADR-012 — ProfileTag 제거 (ProgramProfile 11축 enum 으로 충분)

model ChannelPreset {
  id          String @id @default(cuid())
  code        String @unique // "B2G" | "B2B" | "renewal" (추후 확장)
  displayName String // "정부·공공기관"
  description String @db.Text

  // 톤·메시지
  keyMessages      Json // string[]
  avoidMessages    Json // string[] — 이 타입에서 피해야 할 표현
  tone             String @db.Text
  evaluatorProfile String @db.Text

  // 커리큘럼 가이드
  theoryMaxRatio     Float? // 이론 비율 상한 (B2G 0.3)
  actionWeekMinCount Int? // Action Week 최소 횟수

  // 예산
  budgetTone         String @db.Text
  directCostMinRatio Float? // 직접비 최소 비율

  // 제안서 구조
  proposalStructure String @db.Text

  // 메타
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  source    String   @default("seed") // "seed" | "strategy_interview"
}
