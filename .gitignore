# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# example 파일은 git tracked (다른 개발자 가이드용)
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

.vercel

# Claude Code local settings (personal permissions, not shared)
.claude/settings.local.json

# Planning Agent test scenario debug outputs
scripts/test-output-*.json
scripts/test-output-*.log

# Phase E smoke test outputs (control/treatment 비교 산출물)
scripts/smoke-output/

# Guidebook MkDocs build outputs (Vercel 에서 build.sh 로 생성)
guidebook-site/dist/
guidebook-site/site/

# Ingestion 파일 저장소 (Phase A 임시 — Vercel 배포 시 Blob/S3로 교체 필요)
/storage
.mcp.json

# Playwright (Phase 3.4)
/test-results/
/playwright-report/
/playwright/.cache/
/playwright/.auth/

# Sphere 2 — service account key + 제안서 마스터 시트 + batch result
.secrets/

.claude/scheduled_tasks.lock

# Phase L 검증 — 임시 .md 출력 + tmp 스크립트
.tmp-*.md
.tmp-*.ts
.tmp-*.json
design-kit/diagram-samples/

# 당선 full-text 학습 런 로그 (산출물 — 커밋 X)
learn-fulltext*.log

# 평가위원 품질 스윕 결과 (런 산출물)
scripts/eval-results/
eval-results-*/
eval-sweep.log

# 모든 로그 (eval-ab·smoke·gen-sample 등 transient)
*.log

# smoke 잔재 (gen-sample은 추적 유지)
scripts/_smoke*
scripts/_probe*
*.result.json

# DECK 렌더 전페이지 스냅샷 (재생성 가능 — PDF만 커밋)
docs/samples/snaps/
docs/samples/snaps-spec/
