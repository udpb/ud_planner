# ── 프로덕션 환경변수 (Vercel 대시보드에 직접 입력) ────────────────────────
# Vercel: Project Settings > Environment Variables
# Production / Preview / Development 환경별로 분리 가능
# 절대 .env.production 파일을 git 에 커밋하지 마세요 (.gitignore 에 포함됨)

# ──────────────────────────────────────────────────────────────────
# [필수] 데이터베이스 — Neon PostgreSQL (https://neon.tech 무료 플랜)
# ──────────────────────────────────────────────────────────────────
# 형식: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Vercel 의 Postgres integration 사용 시 자동 주입됨
DATABASE_URL="postgresql://..."

# ──────────────────────────────────────────────────────────────────
# [필수] AI — Phase L1 (2026-04-27) 이후
# ──────────────────────────────────────────────────────────────────
# Google Gemini 3.1 Pro Preview (Primary, 권장)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-pro-preview"

# Anthropic Claude Sonnet 4.6 (Fallback)
ANTHROPIC_API_KEY=""

# ──────────────────────────────────────────────────────────────────
# [필수] NextAuth — 인증
# ──────────────────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열. 생성: openssl rand -base64 32
AUTH_SECRET="생성된_랜덤_문자열"

# 배포 후 Vercel URL 입력 (예: https://ud-ops-workspace-xxx.vercel.app
# 또는 커스텀 도메인). 미설정 시 NextAuth 가 자동 추론하지만 명시 권장.
NEXTAUTH_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ──────────────────────────────────────────────────────────────────
# [선택] Google OAuth — 로그인 기능
# ──────────────────────────────────────────────────────────────────
# 발급: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://your-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ──────────────────────────────────────────────────────────────────
# [선택] GitHub 코치 DB 동기화
# ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_COACHES_REPO="underdogs-org/coaches-db"
GITHUB_COACHES_BRANCH="main"
GITHUB_COACHES_FILE="coaches_db.json"

# 2026-05-03: Google Sheets 연동 폐기 — 코치 단가는 Coach 모델, 피드백 흐름 제거.

# ──────────────────────────────────────────────────────────────────
# [강력 권장] Supabase mirror — Phase Bridge 1 (2026-05-03)
# ──────────────────────────────────────────────────────────────────
# ud-ops Project 가 생성/수정될 때마다 coaching-log/coach-finder 가 사용하는
# Supabase business_plans 에 자동 mirror.
# 미설정 시 mirror 비활성 (Project 저장은 정상, cross-app lifecycle 깨짐).
# 자세한 설계: ../underdogs-coaching-log/docs/INTEGRATED_ARCHITECTURE.md §4.1
SUPABASE_URL="https://zwvrtxxgctyyctirntzj.supabase.co"
# Supabase Dashboard → Project Settings → API → service_role → "Reveal" 후 복사.
# RLS 우회 슈퍼 키 — 절대 브라우저/git/메신저 노출 금지. 서버 전용.
SUPABASE_SERVICE_ROLE=""

# ─────────────────────────────────────────
# [선택] Sentry 모니터링 — Phase 4-coach-integration (2026-05-03)
# ─────────────────────────────────────────
# 운영 환경에서 적극 권장. logger.error/warn 가 자동 수집.
SENTRY_DSN=""
